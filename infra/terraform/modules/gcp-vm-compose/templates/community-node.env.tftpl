# Generated by Terraform (infra/terraform/modules/gcp-vm-compose). Do not edit on the VM.
# Non-secret container env, shared by cn-user-api and cn-iroh-relay via env_file.
# Secrets are injected separately through the project .env at boot.

# --- cn-user-api ---
COMMUNITY_NODE_BIND_ADDR=0.0.0.0:${api_port}
COMMUNITY_NODE_DATABASE_INIT_MODE=require_ready
COMMUNITY_NODE_RENDEZVOUS_KEY_PREFIX=${rendezvous_key_prefix}
COMMUNITY_NODE_BASE_URL=https://${api_domain}
COMMUNITY_NODE_PUBLIC_BASE_URL=https://${api_domain}
COMMUNITY_NODE_CONNECTIVITY_URLS=https://${relay_domain}
COMMUNITY_NODE_JWT_ISSUER=${jwt_issuer}
COMMUNITY_NODE_JWT_TTL_SECONDS=${jwt_ttl_seconds}
COMMUNITY_NODE_RATE_LIMIT_ENABLED=${rate_limit_enabled}
COMMUNITY_NODE_RATE_LIMIT_PER_SECOND=${rate_limit_per_second}
COMMUNITY_NODE_RATE_LIMIT_BURST=${rate_limit_burst}
# Caddy は信頼できる reverse proxy なので、クライアント単位 rate limit のため
# X-Forwarded-For を信頼させる。
COMMUNITY_NODE_RATE_LIMIT_TRUST_FORWARDED_FOR=true

# --- cn-iroh-relay ---
COMMUNITY_NODE_IROH_RELAY_HTTP_BIND_ADDR=0.0.0.0:${relay_http_port}
COMMUNITY_NODE_IROH_RELAY_QUIC_BIND_ADDR=0.0.0.0:${relay_quic_internal_port}
COMMUNITY_NODE_IROH_RELAY_TLS_CERT_PATH=${certs_mount}/live/${cert_name}/fullchain.pem
COMMUNITY_NODE_IROH_RELAY_TLS_KEY_PATH=${certs_mount}/live/${cert_name}/privkey.pem
%{ if iroh_relay_client_rx_bytes_per_second > 0 ~}
COMMUNITY_NODE_IROH_RELAY_CLIENT_RX_BYTES_PER_SECOND=${iroh_relay_client_rx_bytes_per_second}
%{ endif ~}
%{ if iroh_relay_client_rx_max_burst_bytes > 0 ~}
COMMUNITY_NODE_IROH_RELAY_CLIENT_RX_MAX_BURST_BYTES=${iroh_relay_client_rx_max_burst_bytes}
%{ endif ~}

# --- blob cache (informational; disabled by default) ---
# blob/media 本体は Postgres に保存しない。enabled 時も rebuildable cache として扱い、
# backup 対象外の専用 path に置く。
KUKURI_BLOB_CACHE_ENABLED=${blob_cache_enabled}
KUKURI_BLOB_CACHE_TTL_HOURS=${blob_cache_ttl_hours}
KUKURI_BLOB_CACHE_PATH=${blob_cache_path}
