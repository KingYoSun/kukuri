POSTGRES_USER=cn
POSTGRES_PASSWORD=cn_password
POSTGRES_DB=cn
DATABASE_URL=postgres://cn:cn_password@postgres:5432/cn

# Adjust if user-api is published on a different hostname.
PUBLIC_BASE_URL=http://localhost/api

NODE_KEY_PATH=/data/node_key.json
PERSONAL_DATA_EXPORT_DIR=/data/personal_exports
PERSONAL_DATA_HMAC_SECRET=change-me

USER_API_ADDR=0.0.0.0:8080
USER_JWT_SECRET=change-me
USER_JWT_TTL_SECONDS=900
USER_CONFIG_POLL_SECONDS=30

ADMIN_API_ADDR=0.0.0.0:8081
ADMIN_CONFIG_POLL_SECONDS=30
ADMIN_HEALTH_POLL_SECONDS=10
ADMIN_HEALTH_TARGETS=
USER_API_HEALTH_URL=http://user-api:8080/healthz
RELAY_HEALTH_URL=http://relay:8082/healthz
BOOTSTRAP_HEALTH_URL=http://bootstrap:8083/healthz
INDEX_HEALTH_URL=http://index:8084/healthz
MODERATION_HEALTH_URL=http://moderation:8085/healthz

RELAY_ADDR=0.0.0.0:8082
RELAY_P2P_BIND=0.0.0.0:11223
RELAY_P2P_SECRET_KEY=
RELAY_PUBLIC_URL=wss://relay.kukuri.app/relay
RELAY_P2P_PUBLIC_HOST=relay.kukuri.app
RELAY_P2P_PUBLIC_PORT=11223
RELAY_IROH_RELAY_MODE=custom
RELAY_IROH_RELAY_URLS=https://iroh-relay.kukuri.app
RELAY_TOPIC_POLL_SECONDS=30
RELAY_CONFIG_POLL_SECONDS=30
RELAY_P2P_INFO_URL=http://relay:8082/v1/p2p/info
RELAY_HOST_BIND_IP=10.73.0.2
RELAY_P2P_HOST_BIND_IP=10.73.0.2

# VPS Caddy terminates HTTPS on 443/tcp. QUIC address discovery on 7842/udp
# requires the same public certificate/key to be copied under docker/iroh-relay/certs.
IROH_RELAY_DEV=0
IROH_RELAY_CONFIG_PATH=
IROH_RELAY_ENABLE_QUIC_ADDR_DISCOVERY=1
IROH_RELAY_HTTP_BIND_ADDR=0.0.0.0:3340
IROH_RELAY_HTTPS_BIND_ADDR=0.0.0.0:443
IROH_RELAY_QUIC_BIND_ADDR=0.0.0.0:7842
IROH_RELAY_TLS_CERT_MODE=Manual
IROH_RELAY_TLS_CERT_DIR=/certs
IROH_RELAY_TLS_MANUAL_CERT_PATH=/certs/default.crt
IROH_RELAY_TLS_MANUAL_KEY_PATH=/certs/default.key
IROH_RELAY_TLS_PROD=1
IROH_RELAY_TLS_DANGEROUS_HTTP_ONLY=1
IROH_RELAY_TLS_HOSTNAME=
IROH_RELAY_TLS_CONTACT=
IROH_RELAY_LOG_LEVEL=info
IROH_RELAY_PUBLIC_URL=https://iroh-relay.kukuri.app
IROH_RELAY_HOST_BIND_IP=10.73.0.2
IROH_RELAY_CERTS_HOST_PATH=./docker/iroh-relay/certs

BOOTSTRAP_ADDR=0.0.0.0:8083
BOOTSTRAP_REFRESH_SECONDS=300

INDEX_ADDR=0.0.0.0:8084
INDEX_CONFIG_POLL_SECONDS=30

MODERATION_ADDR=0.0.0.0:8085
MODERATION_CONFIG_POLL_SECONDS=30

TRUST_ADDR=0.0.0.0:8086
TRUST_CONFIG_POLL_SECONDS=30

OPENAI_API_KEY=
LLM_PROVIDER=disabled
LLM_LOCAL_ENDPOINT=http://ollama:11434

ADMIN_SESSION_SECRET=change-me
ADMIN_JWT_SECRET=

RELAY_AUTH_REQUIRED=false
BOOTSTRAP_AUTH_REQUIRED=false
