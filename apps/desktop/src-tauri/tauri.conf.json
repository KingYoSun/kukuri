{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "kukuri",
  "version": "0.1.0",
  "identifier": "app.kukuri.desktop",
  "build": {
    "beforeDevCommand": "npx pnpm@10.16.1 vite --host 127.0.0.1 --port 5173 --strictPort",
    "devUrl": "http://127.0.0.1:5173",
    "beforeBuildCommand": "npx pnpm@10.16.1 build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "kukuri",
        "width": 1280,
        "height": 840
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": false
  }
}
