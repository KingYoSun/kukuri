{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "kukuri",
  "version": "0.1.0",
  "identifier": "app.kukuri.desktop",
  "build": {
    "beforeDevCommand": "npx pnpm@10.16.1 vite --host 127.0.0.1 --port 5173 --strictPort",
    "devUrl": "http://127.0.0.1:5173",
    "beforeBuildCommand": "npx pnpm@10.16.1 build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "kukuri",
        "width": 1280,
        "height": 840
      }
    ],
    "security": {
      "csp": {
        "default-src": "'self'",
        "connect-src": "'self' https://github.com https://api.github.com https://*.githubusercontent.com https://api.kukuri.app https://iroh-relay.kukuri.app",
        "img-src": "'self' asset: http://asset.localhost blob: data: https:",
        "media-src": "'self' asset: http://asset.localhost blob: data:",
        "style-src": "'self' 'unsafe-inline'",
        "script-src": "'self'",
        "font-src": "'self' data:",
        "object-src": "'none'",
        "base-uri": "'none'",
        "frame-ancestors": "'none'"
      }
    }
  },
  "plugins": {
    "deep-link": {
      "desktop": {
        "schemes": ["kukuri"]
      }
    },
    "updater": {
      "active": true,
      "endpoints": [
        "https://github.com/KingYoSun/kukuri/releases/latest/download/latest-preview.json"
      ],
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IEQ1NDREMDEwNjM3NUY5QTkKUldTcCtYVmpFTkJFMWFldExjWDRodFM5VlNRV3ZJNUVpUXFKM0hIeVl5MWxpUlg3Z3BJVUJYcFoK"
    }
  },
  "bundle": {
    "active": false
  }
}
